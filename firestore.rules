rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny: Everything not explicitly allowed is forbidden.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // --- Validation Blueprints ---

    function isValidFashionItem(data) {
      return data.imageUrl is string && data.imageUrl.size() < 2048
          && data.category is string && data.category.size() < 100
          && (data.get('style', '') is string && data.get('style', '').size() < 100)
          && (data.get('description', '') is string && data.get('description', '').size() < 5000)
          && (data.get('userId', '') is string)
          && (data.get('tags', []) is list && data.get('tags', []).size() <= 50)
          && data.createdAt == request.time;
    }

    function isValidUserProfile(data) {
      return data.displayName is string && data.displayName.size() < 100
          && data.email == request.auth.token.email
          && (data.get('preferredStyles', []) is list && data.get('preferredStyles', []).size() <= 20)
          && (data.get('recentSearches', []) is list && data.get('recentSearches', []).size() <= 10);
    }

    function isValidMoodboard(data) {
      return data.name is string && data.name.size() < 100
          && (data.get('itemIds', []) is list && data.get('itemIds', []).size() <= 100);
    }

    // --- Collections ---

    match /fashion_items/{itemId} {
      // Global read access for signed-in users
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Creation restricted to verified users
      allow create: if isSignedIn() && isEmailVerified() && isValidId(itemId) 
                    && isValidFashionItem(incoming())
                    && (incoming().get('userId', request.auth.uid) == request.auth.uid);
      
      // Update: only owners can update specific fields
      allow update: if isSignedIn() && isEmailVerified() && isValidId(itemId)
                    && isOwner(existing().get('userId', 'system'))
                    && incoming().diff(existing()).affectedKeys().hasOnly(['category', 'tags', 'style', 'description', 'analysis'])
                    && incoming().createdAt == existing().createdAt;
      
      allow delete: if isSignedIn() && isOwner(existing().get('userId', 'system'));
    }

    match /users/{userId} {
      // Profiles are strictly private
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      
      allow update: if isOwner(userId) 
                    && isValidUserProfile(incoming())
                    && incoming().email == existing().email;
                    
      match /moodboards/{boardId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(boardId) && isValidMoodboard(incoming());
      }
    }
  }
}
